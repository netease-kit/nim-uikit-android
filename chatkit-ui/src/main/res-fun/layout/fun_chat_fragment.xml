<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fun_chat_page_bg_color">

    <com.netease.yunxin.kit.chatkit.ui.fun.view.FunChatView
        android:id="@+id/chatView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout android:id="@+id/chatInvalidTipLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_60_dp"
        android:layout_gravity="bottom"
        android:background="@color/color_eef1f4"
        android:visibility="gone"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/chat_team_error_tip_content"/>
    </FrameLayout>
    <LinearLayout android:id="@+id/messageTipsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="@dimen/dimen_140_dp"
        android:background="@drawable/fun_bg_shape_left_radius"
        android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/dimen_40_dp"
                android:layout_height="@dimen/dimen_40_dp"
                android:src="@drawable/fun_ic_chat_message_arrow_bottom"
                android:scaleType="centerInside"
                />

        <TextView android:id="@+id/messageTipsTv"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_40_dp"
            android:background="@color/color_white"
            android:gravity="center_vertical"
            android:textColor="@color/fun_chat_new_message_tips_color"
            android:textSize="@dimen/text_size_14"
            android:paddingEnd="@dimen/dimen_8_dp"/>

    </LinearLayout>
</FrameLayout>