<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.netease.yunxin.kit.common.ui.widgets.BackTitleBar
        android:id="@+id/searchTitleBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_46_dp"
        app:titleText="@string/chat_calendar_filter_by_date"
        android:background="@color/fun_chat_secondary_page_bg_color"/>

    <LinearLayout
        android:id="@+id/quickRangeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:gravity="start"
        android:background="@color/fun_chat_secondary_page_bg_color">

        <TextView
            android:id="@+id/btnToday"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/fun_bg_quick_range_selector"
            android:text="@string/chat_calendar_quick_today"
            android:textColor="@drawable/fun_text_selected_color"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/btnLast7"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/fun_bg_quick_range_selector"
            android:text="@string/chat_calendar_quick_last_7_days"
            android:textColor="@drawable/fun_text_selected_color"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/btnLast30"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:background="@drawable/fun_bg_quick_range_selector"
            android:text="@string/chat_calendar_quick_last_30_days"
            android:textColor="@drawable/fun_text_selected_color"
            android:textSize="14sp"
            android:gravity="center" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/monthTitleLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvMonthTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_999999"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivMonthDropdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_down"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/chat_calendar_filter_by_date" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/weekHeaderLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_1"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_2"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_3"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_4"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_5"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_6"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chat_week_7"
            android:textColor="@color/color_999999"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:id="@+id/weekDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#dddddd" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCalendar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        android:overScrollMode="never"
        android:paddingBottom="120dp" />

</LinearLayout>
