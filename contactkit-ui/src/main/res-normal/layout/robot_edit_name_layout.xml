<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cly_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/normal_page_bg_second_color">

    <!-- 返回按钮 -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="26dp"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/dimen_20_dp"
        android:src="@drawable/ic_arrow_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 居中标题：昵称 -->
    <TextView
        android:id="@+id/tv_page_title"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="@string/contact_robot_edit_name_page_title"
        android:textColor="@color/color_333333"
        android:textSize="@dimen/text_size_16"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 右侧保存按钮 -->
    <TextView
        android:id="@+id/tv_save"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:gravity="center"
        android:paddingStart="@dimen/dimen_20_dp"
        android:paddingEnd="@dimen/dimen_20_dp"
        android:text="@string/contact_robot_edit_name_done"
        android:textColor="@color/color_contact_blue_primary"
        android:textSize="@dimen/text_size_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 输入框（圆角白色背景） -->
    <EditText
        android:id="@+id/et_name"
        android:layout_width="0dp"
        android:layout_height="@dimen/dimen_46_dp"
        android:layout_marginTop="@dimen/dimen_20_dp"
        android:layout_marginStart="@dimen/dimen_16_dp"
        android:layout_marginEnd="@dimen/dimen_16_dp"
        android:background="@drawable/shape_contact_white_round_8"
        android:gravity="center_vertical"
        android:inputType="text"
        android:maxLength="15"
        android:maxLines="1"
        android:paddingStart="@dimen/dimen_16_dp"
        android:paddingEnd="@dimen/dimen_40_dp"
        android:textColor="@color/color_333333"
        android:textSize="@dimen/text_size_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_page_title" />

    <!-- 清除按钮 -->
    <ImageView
        android:id="@+id/iv_clear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimen_12_dp"
        android:padding="@dimen/dimen_4_dp"
        android:src="@drawable/ic_clear"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/et_name"
        app:layout_constraintEnd_toEndOf="@id/et_name"
        app:layout_constraintTop_toTopOf="@id/et_name" />

    <!-- 字数统计（输入框右下角） -->
    <TextView
        android:id="@+id/tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_6_dp"
        android:layout_marginEnd="@dimen/dimen_16_dp"
        android:textColor="@color/color_999999"
        android:textSize="@dimen/text_size_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_name" />

</androidx.constraintlayout.widget.ConstraintLayout>
