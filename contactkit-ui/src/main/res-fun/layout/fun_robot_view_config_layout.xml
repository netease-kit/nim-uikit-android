<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_ededed"
    android:orientation="vertical">

    <!-- 标题栏 -->
    <com.netease.yunxin.kit.common.ui.widgets.BackTitleBar
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:titleText="@string/contact_robot_view_config_page_title" />

    <!-- 配置串卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_10_dp"
        android:layout_marginHorizontal="@dimen/dimen_16_dp"
        android:background="@color/color_white"
        android:orientation="vertical"
        android:padding="@dimen/dimen_16_dp">

        <!-- 标签 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_robot_view_config_label"
            android:textColor="@color/title_color"
            android:textSize="@dimen/text_size_16"
            android:textStyle="bold" />

        <!-- 配置串内容：最多两行，超出末尾省略 -->
        <TextView
            android:id="@+id/tv_config_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_8_dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/color_666666"
            android:textSize="@dimen/text_size_14" />
    </LinearLayout>

    <!-- 复制按钮 -->
    <TextView
        android:id="@+id/btn_copy"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_46_dp"
        android:layout_marginTop="@dimen/dimen_20_dp"
        android:layout_marginHorizontal="@dimen/dimen_16_dp"
        android:background="@drawable/selector_fun_primary_btn"
        android:gravity="center"
        android:text="@string/contact_robot_view_config_copy"
        android:textColor="@color/color_white"
        android:textSize="@dimen/text_size_16" />

    <!-- 安全提示 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dimen_8_dp"
        android:text="@string/contact_robot_view_config_tip"
        android:textColor="#ff9000"
        android:textSize="@dimen/text_size_12" />

</LinearLayout>
