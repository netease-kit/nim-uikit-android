<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_ededed"
    android:orientation="vertical">

    <!-- 标题栏 -->
    <com.netease.yunxin.kit.common.ui.widgets.BackTitleBar
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:titleText="@string/contact_robot_edit_name_page_title">

        <!-- 右侧保存按钮 -->
        <TextView
            android:id="@+id/tv_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="@dimen/dimen_20_dp"
            android:padding="@dimen/dimen_4_dp"
            android:text="@string/contact_robot_edit_name_done"
            android:textColor="@color/fun_contact_primary_color"
            android:textSize="@dimen/text_size_16" />
    </com.netease.yunxin.kit.common.ui.widgets.BackTitleBar>

    <!-- 输入框（圆角白色背景，与 normal 保持一致） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_20_dp"
        android:layout_marginStart="@dimen/dimen_16_dp"
        android:layout_marginEnd="@dimen/dimen_16_dp">

        <EditText
            android:id="@+id/et_name"
            android:layout_width="0dp"
            android:layout_height="@dimen/dimen_46_dp"
            android:background="@drawable/shape_contact_white_round_8"
            android:gravity="center_vertical"
            android:hint="@string/contact_robot_edit_name_hint"
            android:inputType="text"
            android:maxLength="15"
            android:maxLines="1"
            android:paddingStart="@dimen/dimen_16_dp"
            android:paddingEnd="@dimen/dimen_40_dp"
            android:textColor="@color/title_color"
            android:textSize="@dimen/text_size_16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dimen_12_dp"
            android:padding="@dimen/dimen_4_dp"
            android:src="@drawable/ic_clear"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/et_name"
            app:layout_constraintEnd_toEndOf="@id/et_name"
            app:layout_constraintTop_toTopOf="@id/et_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 字数统计 -->
    <TextView
        android:id="@+id/tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/dimen_6_dp"
        android:layout_marginEnd="@dimen/dimen_16_dp"
        android:textColor="@color/color_999999"
        android:textSize="@dimen/text_size_12" />

</LinearLayout>
