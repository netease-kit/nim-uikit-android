<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/color_white"
    android:minHeight="@dimen/dimen_56_dp"
    android:paddingHorizontal="@dimen/dimen_20_dp"
    android:paddingVertical="@dimen/dimen_10_dp">

    <com.netease.yunxin.kit.common.ui.widgets.ContactAvatarView
        android:id="@+id/avatar_view"
        android:layout_width="@dimen/dimen_46_dp"
        android:layout_height="@dimen/dimen_46_dp"
        android:layout_centerVertical="true"
        app:avatarCorner="@dimen/dimen_6_dp"
        app:avatarTextSize="@dimen/text_size_16" />

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/dimen_15_dp"
        android:layout_marginEnd="@dimen/dimen_8_dp"
        android:layout_toStartOf="@+id/iv_arrow"
        android:layout_toEndOf="@+id/avatar_view"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/title_color"
        android:textSize="@dimen/text_size_16" />

    <ImageView
        android:id="@+id/iv_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_right_arrow" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_1_dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/dimen_80_dp"
        android:background="@color/color_f5f8fc" />

</RelativeLayout>
