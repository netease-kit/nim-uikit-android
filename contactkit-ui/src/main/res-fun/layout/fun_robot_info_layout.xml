<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_ededed"
    android:orientation="vertical">

    <!-- 标题栏 -->
    <com.netease.yunxin.kit.common.ui.widgets.BackTitleBar
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fun_contact_page_primary_bg_color"
        app:titleText="@string/contact_robot_info_title" />

    <!-- 头像 + 名称 区域 -->
    <LinearLayout
        android:id="@+id/rly_avatar_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fun_contact_page_primary_bg_color"
        android:orientation="horizontal"
        android:padding="@dimen/dimen_20_dp">

        <com.netease.yunxin.kit.common.ui.widgets.ContactAvatarView
            android:id="@+id/avatar_view"
            android:layout_width="@dimen/dimen_46_dp"
            android:layout_height="@dimen/dimen_46_dp"
            app:avatarCorner="@dimen/dimen_6_dp"
            app:avatarTextSize="@dimen/text_size_16" />

        <TextView
            android:id="@+id/tv_robot_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/dimen_15_dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/title_color"
            android:textSize="@dimen/text_size_16" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_right_arrow" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_10_dp"
        android:background="@color/color_ededed" />

    <!-- 操作列表区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_white"
        android:orientation="vertical">

        <!-- 编辑（Normal 版通过 setupEditEntry 控制显隐） -->
        <RelativeLayout
            android:id="@+id/rly_edit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_46_dp"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="@dimen/dimen_20_dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/contact_robot_edit"
                android:textColor="@color/title_color"
                android:textSize="@dimen/text_size_16" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_right_arrow" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_1_dp"
                android:layout_alignParentBottom="true"
                android:background="@color/color_f5f8fc" />
        </RelativeLayout>

        <!-- 查看配置串 -->
        <RelativeLayout
            android:id="@+id/rly_view_config"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_46_dp"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="@dimen/dimen_20_dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/contact_robot_view_config"
                android:textColor="@color/title_color"
                android:textSize="@dimen/text_size_16" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_right_arrow" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_1_dp"
                android:layout_alignParentBottom="true"
                android:background="@color/color_f5f8fc" />
        </RelativeLayout>

        <!-- 刷新Token -->
        <RelativeLayout
            android:id="@+id/rly_refresh_token"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_46_dp"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="@dimen/dimen_20_dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/contact_robot_refresh_token"
                android:textColor="@color/title_color"
                android:textSize="@dimen/text_size_16" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_right_arrow" />
        </RelativeLayout>
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_10_dp"
        android:background="@color/color_ededed" />

    <!-- 聊天 + 删除机器人 区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_white"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_chat"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_46_dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/contact_robot_chat"
            android:textColor="#525C8C"
            android:textSize="@dimen/text_size_16" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_1_dp"
            android:background="@color/color_f5f8fc" />

        <TextView
            android:id="@+id/tv_delete"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_46_dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/contact_robot_delete"
            android:textColor="@color/color_e6605c"
            android:textSize="@dimen/text_size_16" />
    </LinearLayout>

</LinearLayout>
